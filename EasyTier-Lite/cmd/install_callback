#!/bin/bash

### This script is called after the user installs the application.
set -e

source /var/apps/${TRIM_APPNAME}/cmd/common.sh

mkdir -p "$(dirname ${LOG_FILE})"

active_py() {
    log_msg "创建虚拟环境"
    run_cmd "/usr/bin/python3 -m venv ${SCRIPT_PATH}/.venv"
    log_msg "安装离线依赖"
    run_cmd "${SCRIPT_PATH}/.venv/bin/pip install --no-index --find-links=${SCRIPT_PATH}/wheels -r ${SCRIPT_PATH}/requirements-base.txt"
}

active_py
